#!/usr/bin/env bash
set -euo pipefail

session_id="${1:-}"
path="${2:-$PWD}"

if [[ -z "$session_id" ]]; then
  exit 0
fi

markers=(
  .git
  flake.nix
  package.json
  pyproject.toml
  go.mod
  Cargo.toml
)

find_project_root() {
  local dir="$1"

  if git -C "$dir" rev-parse --show-toplevel >/dev/null 2>&1; then
    git -C "$dir" rev-parse --show-toplevel
    return 0
  fi

  while [[ "$dir" != "/" ]]; do
    local marker
    for marker in "${markers[@]}"; do
      if [[ -e "$dir/$marker" ]]; then
        printf '%s\n' "$dir"
        return 0
      fi
    done
    dir="$(dirname -- "$dir")"
  done

  return 1
}

sanitize_segment() {
  printf '%s' "$1" \
    | tr '/[:space:]' '.' \
    | tr -cs '[:alnum:]._-' '_' \
    | sed -E 's/^[._-]+//; s/[._-]+$//; s/[.]+/./g'
}

build_name() {
  local dir="$1"
  local root rel project leaf

  if root="$(find_project_root "$dir" 2>/dev/null)"; then
    project="$(basename -- "$root")"
    if [[ "$dir" == "$root" ]]; then
      sanitize_segment "$project"
      return 0
    fi

    rel="${dir#"$root"/}"
    printf '%s.%s\n' "$(sanitize_segment "$project")" "$(sanitize_segment "$rel")"
    return 0
  fi

  leaf="$(basename -- "$dir")"
  if [[ "$leaf" == "/" || "$leaf" == "." || -z "$leaf" ]]; then
    leaf="home"
  fi
  sanitize_segment "$leaf"
}

unique_name() {
  local base="$1"
  local candidate="$base"
  local current existing suffix=2

  current="$(tmux display-message -p -t "$session_id" '#{session_name}' 2>/dev/null || true)"
  while :; do
    existing="$(tmux list-sessions -F '#{session_name}\t#{session_id}' 2>/dev/null | awk -F '\t' -v name="$candidate" '$1 == name { print $2; exit }')"
    if [[ -z "$existing" || "$candidate" == "$current" || "$existing" == *":$session_id" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
    candidate="${base}-${suffix}"
    suffix=$((suffix + 1))
  done
}

name="$(build_name "$path")"
[[ -n "$name" ]] || name="tmux"
name="$(unique_name "$name")"
current_name="$(tmux display-message -p -t "$session_id" '#{session_name}' 2>/dev/null || true)"

if [[ -n "$name" && "$name" != "$current_name" ]]; then
  tmux rename-session -t "$session_id" "$name" >/dev/null 2>&1 || true
fi

printf '%s' "$name"
